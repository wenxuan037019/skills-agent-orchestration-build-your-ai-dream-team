{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Project Pulse Dashboard",
      "type": "node",
      "request": "launch",
      "skipFiles": ["<node_internals>/**"],
      "command": "python3",
      "args": ["-m", "http.server", "5500"],
      "cwd": "${workspaceFolder}/app",
      "serverReadyAction": {
        "pattern": "Serving HTTP on",
        "uriFormat": "http://localhost:%s/index.html",
        "action": "openExternally"
      }
    }
  ]
}
